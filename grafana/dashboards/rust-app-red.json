{
  "uid": "rust-app-red",
  "title": "Rust App — RED metrics (HTTP)",
  "tags": ["rust", "red", "mimir"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate per route (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_route) (rate(http_server_request_duration_count{job=\"rust-observability-test\"}[1m]))",
          "legendFormat": "{{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(http_server_request_duration_count{job=\"rust-observability-test\",http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_count{job=\"rust-observability-test\"}[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 per route",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "refId": "p50",
          "expr": "histogram_quantile(0.50, sum by (le, http_route) (rate(http_server_request_duration_bucket{job=\"rust-observability-test\"}[5m])))",
          "legendFormat": "p50 {{http_route}}",
          "exemplar": false
        },
        {
          "refId": "p95",
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_bucket{job=\"rust-observability-test\"}[5m])))",
          "legendFormat": "p95 {{http_route}}",
          "exemplar": false
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum by (le, http_route) (rate(http_server_request_duration_bucket{job=\"rust-observability-test\"}[5m])))",
          "legendFormat": "p99 {{http_route}}",
          "exemplar": false
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Status code distribution",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_count{job=\"rust-observability-test\"}[1m]))",
          "legendFormat": "{{http_response_status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "^2.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byRegexp", "options": "^4.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byRegexp", "options": "^5.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    }
  ]
}
